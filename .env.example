# Copy this file to `.env.local` next to __init__.py and fill in your key.
# The plugin looks for GOOGLE_API_KEY (GEMINI_API_KEY is also accepted).

GOOGLE_API_KEY=your_gemini_api_key_here

# Optional — model override. Default: gemini-2.5-flash
# AGENTIC_PYMOL_MODEL=gemini-2.5-pro

# Optional — hard timeout for a single run_pymol_python call, in seconds. Default: 60
# AGENTIC_PYMOL_TIMEOUT=60

# Optional — max recursion depth for the main agent. Default: 50
# AGENTIC_PYMOL_RECURSION=50
