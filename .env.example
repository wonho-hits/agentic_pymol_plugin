# Copy this file to `.env.local` next to __init__.py and fill in your key.
# The plugin looks for GOOGLE_API_KEY (GEMINI_API_KEY is also accepted).

GOOGLE_API_KEY=your_gemini_api_key_here

# Optional — model override. Default: gemini-3-flash-preview
# AGENTIC_PYMOL_MODEL=gemini-2.5-pro

# Optional — hard timeout for a single run_pymol_python call, in seconds. Default: 60
# AGENTIC_PYMOL_TIMEOUT=60

# Optional — max recursion depth for the main agent. Default: 50
# AGENTIC_PYMOL_RECURSION=50

# When the plugin is installed via the Plugin Manager (zip), the agent/ project
# is NOT copied along with it. Point at it explicitly with one of:
#   AGENTIC_PYMOL_AGENT_PYTHON — absolute path to agent/.venv/bin/python.
#       AGENTIC_PYMOL_AGENT_DIR is then derived as its grandparent's parent.
#   AGENTIC_PYMOL_AGENT_DIR    — absolute path to the agent/ project root,
#       overriding the auto-derived value.
# AGENTIC_PYMOL_AGENT_PYTHON=/absolute/path/to/agent/.venv/bin/python
# AGENTIC_PYMOL_AGENT_DIR=/absolute/path/to/agent
